{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://news-portal-production.up.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://news-portal-production.up.railway.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}
